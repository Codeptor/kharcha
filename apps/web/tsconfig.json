{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["bun-types", "node"],
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/usage-core": ["../../packages/usage-core/src/index.ts"],
      "@workspace/usage-core/*": ["../../packages/usage-core/src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.astro"
  ],
  "exclude": ["node_modules"]
}
